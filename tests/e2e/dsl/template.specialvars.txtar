# SETUP: construct working folder layout
exec cp $REPODIR/tests/scripts/workflow.sh $WORKDIR/workflow.sh
exec cp -r . $WORKDIR
cd $WORKDIR


# TEST: operate the simulation
env FILE_NAME=remote_foo
env EV_MSG='"Hello from envar"'
env
exec sh -e workflow.sh openloop.dse

exists out/downloads/models/simple/remote_foo.txt
exists out/sim/model/simple/data/remote_foo.txt
cmp out/downloads/models/simple/remote_foo.txt out/sim/model/simple/data/remote_foo.txt
stdout 'MSG=Hello from envar'


-- openloop.dse --
simulation
channel signal

uses
dse.sdp https://github.com/boschglobal/dse.sdp v$RELEASE_VERSION
input file:///repo/tests/testdata/e2e/files.zip path=testdata/$FILE_NAME.txt

model simple Simple
channel signal signal_vector
file remote_foo.txt uses input
workflow message
var MSG {{.EV_MSG}}
