# SETUP: construct working folder layout
exec cp $REPODIR/tests/scripts/workflow.sh $WORKDIR/workflow.sh
exec cp -r . $WORKDIR
cd $WORKDIR
exec sh -c 'echo >> openloop.dse'
exec sh -c 'echo "-- input.csv --" >> openloop.dse'
exec sh -c 'cat input.csv >> openloop.dse'

# TEST: operate the simulation (builder only — verifies txtar extraction)
exec sh -e workflow.sh openloop.dse BUILD_ONLY
exists out/sim/model/input/data/input.csv
cmp input.csv out/sim/model/input/data/input.csv

-- openloop.dse --
simulation
channel signal

uses
dse.sdp https://github.com/boschglobal/dse.sdp v$RELEASE_VERSION

model input Simple
channel signal signal_vector
file input.csv input.csv

-- input.csv --
Timestamp;input;factor;offset
0.0000;1.0;2.0;3.0
0.0005;-1.1;2.1;3.1
0.0010;1.2;-2.2;3.2
0.0015;1.3;2.3;-3.3
