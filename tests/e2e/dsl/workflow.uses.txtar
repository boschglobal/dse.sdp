skip 'TODO: test after RELEASE_VERSION update'
# SETUP: construct working folder layout
exec cp $REPODIR/tests/scripts/workflow.sh $WORKDIR/workflow.sh
exec cp -r . $WORKDIR
cd $WORKDIR

# TEST: operate the simulation
exec sh -e workflow.sh simple.dse BUILD_ONLY

exists sim/repo/workflow/message.txt
stdout 'Hello from repo workflow'

-- simple.dse --
simulation
channel signal

uses
dse.sdp file:///repo v$PACKAGE_VERSION

model simple Simple
channel signal signal_channel
workflow write-message
var PATH {{.SIMDIR}}/repo/workflow
var FILE message.txt
var MESSAGE "Hello from repo workflow"
