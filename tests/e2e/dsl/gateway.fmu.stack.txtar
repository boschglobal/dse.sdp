# SETUP: construct working folder layout
exec cp $REPODIR/tests/scripts/workflow.sh $WORKDIR/workflow.sh
exec cp -r . $WORKDIR
cd $WORKDIR

# TEST: operate the simulation
exec sh -e workflow.sh openloop.dse BUILD_ONLY

grep 'stack-default:' Taskfile.yml
grep 'stack-gateway:' Taskfile.yml

exec yq '.tasks."stack-default".deps[].task' Taskfile.yml
stdout 'model-input'
stdout 'model-linear'

exec yq '.tasks."stack-gateway".deps[].task' Taskfile.yml
stdout 'model-gateway_fmu'

-- openloop.dse --
simulation arch=linux-amd64
channel physical

uses
dse.modelc https://github.com/boschglobal/dse.modelc v2.1.32
dse.fmi https://github.com/boschglobal/dse.fmi v1.1.48
linear_fmu https://github.com/boschglobal/dse.fmi/releases/download/v1.1.48/Fmi-1.1.48-linux-amd64.zip path=examples/fmu/linear/fmi2/linear.fmu


model input dse.modelc.csv
channel physical signal_channel
envar CSV_FILE model/input/data/input.csv
envar SIMBUS_LOGLEVEL 5
file input.csv data/input.csv
file signalgroup.yaml data/input_sg.yaml

model linear dse.fmi.mcl
channel physical signal_channel
envar MEASUREMENT_FILE /sim/measurement.mf4
envar SIMBUS_LOGLEVEL 2
workflow generate-fmimcl
 var FMU_DIR uses linear_fmu
 var OUT_DIR {{.PATH}}/data
 var MCL_PATH {{.PATH}}/lib/libfmimcl.so

stack gateway
model gateway_fmu dse.fmi.mcl
channel physical signal_channel
file signalgroup.yaml out/sim/model/linear/data/signalgroup.yaml # dependent file from another model
file patch.csv data/patch.csv
workflow patch-signalgroup
var INPUT {{.PATH}}/data/signalgroup.yaml
var PATCH {{.PATH}}/data/patch.csv

-- data/input.csv --
Timestamp;input;factor;offset
0.0000;1.0;2.0;3.0
0.0005;-1.1;2.1;3.1
0.0010;1.2;-2.2;3.2
0.0015;1.3;2.3;-3.3

-- data/input_sg.yaml --
---
kind: SignalGroup
metadata:
  name: signal_vector
  labels:
    channel: signal_vector
    model: input
spec:
  signals:
    - signal: input
    - signal: factor
    - signal: offset

-- data/patch.csv --
source,target
input,input_patched
