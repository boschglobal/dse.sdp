# SETUP: construct working folder layout
exec cp $REPODIR/tests/scripts/workflow.sh $WORKDIR/workflow.sh
exec cp -r . $WORKDIR
cd $WORKDIR

# TEST: operate the simulation
exec sh -e workflow.sh openloop.dse BUILD_ONLY

exists out/sim/model/simple/data/local_files/foo.txt
cmp local_foo.txt out/sim/model/simple/data/local_files/foo.txt

-- openloop.dse --
simulation
channel signal

uses
dse.sdp https://github.com/boschglobal/dse.sdp v$RELEASE_VERSION

model simple Simple
channel signal signal_vector
file local_files/foo.txt local_foo.txt

-- local_foo.txt --
local foo
