exec cp $REPODIR/tests/scripts/workflow.sh $WORKDIR/workflow.sh

env EXAMPLE_DIR=$REPODIR/examples/runnable
exec cp $EXAMPLE_DIR/runnable.dse $WORKDIR/
exec cp -r . $WORKDIR
cd $WORKDIR

# TEST: operate the simulation
exec sh -e workflow.sh runnable.dse

