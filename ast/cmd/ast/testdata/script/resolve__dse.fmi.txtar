env
exec mkdir -p out
exec ast resolve -input ast.yaml -uses dse.fmi -file md_dse.fmi.yaml
exec ls -R $WORK
exec cat out/ast.yaml

yamlcontains out/ast.yaml $.kind Simulation

yamlcontains out/ast.yaml $.spec.vars[0].name sim_key
yamlcontains out/ast.yaml $.spec.vars[0].value sim_value

yamlcontains out/ast.yaml $.spec.stacks[0].models[0].name linear
yamlcontains out/ast.yaml $.spec.stacks[0].models[0].uses dse.fmi
yamlcontains out/ast.yaml $.spec.stacks[0].models[0].workflows[0].name generate-fmimcl
yamlcontains out/ast.yaml $.spec.stacks[0].models[0].workflows[0].vars[0].name FMU_DIR

yamlcontains out/ast.yaml $.spec.stacks[0].models[0].metadata.models.fmimcl.name fmimcl
yamlcontains out/ast.yaml $.spec.stacks[0].models[0].metadata.models.fmimcl.path dse/fmimcl
yamlcontains out/ast.yaml $.spec.stacks[0].models[0].metadata.models.fmimcl.displayName dse.fmi.mcl
yamlcontains out/ast.yaml $.spec.stacks[0].models[0].metadata.models.fmimcl.files[0] fmimcl/lib/libfmimcl.so
yamlcontains out/ast.yaml $.spec.stacks[0].models[0].metadata.models.fmimcl.platforms[0] linux-amd64
yamlcontains out/ast.yaml $.spec.stacks[0].models[0].metadata.models.fmimcl.workflows[0] generate-fmimcl

yamlcontains out/ast.yaml $.spec.uses[0].name dse.fmi
yamlcontains out/ast.yaml $.spec.uses[0].url https://github.com/boschglobal/dse.fmi
yamlcontains out/ast.yaml $.spec.uses[0].version v1.1.20

-- out/ast.yaml --
---
kind: Simulation
spec:
  arch: linux-amd64
  channels:
    - name: physical
  stacks:
    - name: default
      models:
        - name: linear
          model: fmimcl
          uses: dse.fmi
          channels:
            - alias: scalar_vector
              name: physical
          workflows:
            - name: generate-fmimcl
              vars:
                - name: FMU_DIR
                  reference: uses
                  value: linear_fmu
                - name: OUT_DIR
                  value: '{{.PATH}}/data'
                - name: MCL_PATH
                  value: '{{.PATH}}/lib/libfmimcl.so'
  uses:
    - name: dse.fmi
      url: https://github.com/boschglobal/dse.fmi
      version: v1.1.20
      metadata:
        container:
          repository: ghcr.io/boschglobal/dse-fmi
          image_var: FMI_IMAGE
          tag_var: FMI_TAG
    - name: linear_fmu
      url: https://github.com/boschglobal/dse.fmi/releases/download/v1.1.20/Fmi-1.1.20-linux-amd64.zip
      path: examples/fmu/linear/fmi2/linear.fmu
      metadata: {}

  vars:
    - name: sim_key
      value: sim_value


-- md_dse.fmi.yaml --
---
metadata:
  package:
    download: '{{.REPO}}/releases/download/v{{.TAG}}/Fmi-{{.TAG}}-{{.PLATFORM_ARCH}}.zip'
  container:
    repository: ghcr.io/boschglobal/dse-fmi
    image_var: FMI_IMAGE
    tag_var: FMI_TAG
  models:
    fmimcl:
      name: fmimcl
      displayName: dse.fmi.mcl
      path: dse/fmimcl
      files:
        - fmimcl/lib/libfmimcl.so
      workflows:
        - generate-fmimcl
        - patch-signalgroup
      platforms:
        - linux-amd64
        - linux-x86
        - linux-i386
        - windows-x64
        - windows-x86
      channels:
        - alias: scalar_vector
        - alias: network_vector
